# =============================================================================
# Example environment configuration for the local Compose stack.
# Copy this file to `.env` and adjust values as needed:
#     cp .env.example .env
#
# NOTE: `.env` holds LOCAL secrets only and must never be committed.
#       Production secrets are managed via Kubernetes Secrets (project part 2).
# =============================================================================

# ---- PostgreSQL -----------------------------------------------------------
POSTGRES_DB=ticketing
POSTGRES_USER=ticketing_user
POSTGRES_PASSWORD=change_me_local      # local development value only
POSTGRES_HOST=postgres                 # service name on the compose network
POSTGRES_PORT=5432

# ---- Redis (queue / cache) ------------------------------------------------
REDIS_HOST=redis                       # service name on the compose network
REDIS_PORT=6379

# ---- Service ports (host:container) ---------------------------------------
API_PORT=8080
FRONTEND_PORT=3000

# ---- Frontend -> API ------------------------------------------------------
# The browser running on the host calls the API on its published host port.
API_BASE_URL=http://localhost:8080

# ---- Worker / queue -------------------------------------------------------
QUEUE_NAME=ticket_orders

# ---- Runtime --------------------------------------------------------------
NODE_ENV=development
